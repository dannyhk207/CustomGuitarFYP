<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Guitar Shop - Custom Guitar Builder</title>
    <style>
        :root {
            --primary: #1a1a2e;
            --secondary: #16213e;
            --accent: #e94560;
            --gold: #d4af37;
            --success: #0f4c5b;
            --light: #f8f9fa;
            --dark: #212529;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            --border-radius: 12px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, var(--secondary) 0%, var(--primary) 50%, #0f3460 100%);
            min-height: 100vh;
            color: var(--light);
            overflow-x: hidden;
            padding-top: 80px;
            /* Space for fixed navbar */
        }

        /* FIXED NAVBAR */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(26, 26, 46, 0.98);
            backdrop-filter: blur(20px);
            z-index: 1000;
            padding: 1rem 0;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 2rem;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(45deg, var(--accent), var(--gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        .nav-links a {
            color: var(--light);
            text-decoration: none;
            font-weight: 500;
            transition: var(--transition);
            position: relative;
            padding: 0.5rem 0;
        }

        .nav-links a:hover {
            color: var(--accent);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--accent), var(--gold));
            transition: var(--transition);
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        /* MOBILE MENU BUTTON */
        .mobile-menu {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 4px;
        }

        .mobile-menu span {
            width: 25px;
            height: 3px;
            background: var(--light);
            border-radius: 2px;
            transition: var(--transition);
        }

        /* MAIN CONTENT */
        .customizer {
            max-width: 900px;
            margin: 2rem auto;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px);
            border-radius: var(--border-radius);
            padding: 3rem;
            box-shadow: var(--shadow);
            border: 1px solid rgba(255, 255, 255, 0.2);
            animation: slideIn 0.8s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h1 {
            text-align: center;
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            background: linear-gradient(45deg, var(--accent), var(--gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 2.5rem;
        }

        /* OPTIONS GRID - FIXED LAYOUT */
        .options-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .option-group {
            background: rgba(255, 255, 255, 0.05);
            padding: 1.5rem;
            border-radius: var(--border-radius);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: var(--transition);
        }

        .option-group:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.75rem;
            color: var(--light);
            font-size: 1rem;
        }

        select,
        textarea {
            width: 100%;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.95);
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            font-size: 16px;
            color: var(--dark);
        }

        select:focus,
        textarea:focus {
            border-color: var(--accent);
            outline: none;
        }

        textarea {
            resize: vertical;
            min-height: 100px;
            grid-column: 1 / -1;
            /* Full width */
        }

        /* PREVIEW - FIXED */
        .preview-section {
            text-align: center;
            margin: 2rem 0;
        }

        .guitar-preview {
            width: 100%;
            max-width: 350px;
            height: 220px;
            margin: 0 auto;
            border-radius: 15px;
            padding: 1.5rem;
            background: #e0e0e0;
            box-shadow: var(--shadow);
            position: relative;
            color: #333;
        }

        /* BUTTON */
        .build-btn {
            background: linear-gradient(45deg, var(--accent), var(--gold));
            color: white;
            padding: 1.25rem 2.5rem;
            border: none;
            border-radius: var(--border-radius);
            font-size: 1.2rem;
            font-weight: 700;
            cursor: pointer;
            width: 100%;
            transition: var(--transition);
            text-transform: uppercase;
        }

        .build-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(233, 69, 96, 0.4);
        }

        /* SUMMARY */
        #summary {
            margin-top: 2rem;
            padding: 2rem;
            background: rgba(15, 76, 91, 0.9);
            border-radius: var(--border-radius);
            display: none;
        }

        /* MOBILE RESPONSIVE */
        @media (max-width: 768px) {
            .mobile-menu {
                display: flex;
            }

            .nav-links {
                display: none;
            }

            .customizer {
                margin: 1rem;
                padding: 1.5rem;
            }

            .options-grid {
                grid-template-columns: 1fr;
                gap: 1rem;
            }
        }

        @media (max-width: 480px) {
            .nav-container {
                padding: 0 1rem;
            }
        }
    </style>
</head>

<body>
    <!-- FIXED NAVBAR -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="logo">🎸 Jackie's Guitars</a>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/#featured">Features</a></li>
                <li><a href="/customize">Custom Builder</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
            <div class="mobile-menu">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <div class="customizer">
        <h1>🎸 Custom Guitar Builder</h1>

        <div class="option-group">
            <label for="shape">Body Shape:</label>
            <select id="shape">
                <option value="Dreadnought">Dreadnought</option>
                <option value="Stratocaster">Stratocaster</option>
                <option value="Les Paul">Les Paul</option>
                <option value="Telecaster">Telecaster</option>
                <option value="Parlor">Parlor</option>
                <option value="Auditorium">Auditorium</option>[web:1][web:8]
            </select>
        </div>
        <br>
        <div class="option-group">
            <label for="color">Body Color:</label>
            <select id="color">
                <option value="Sunburst">Sunburst</option>
                <option value="Black">Black</option>
                <option value="White">White</option>
                <option value="Seafoam Green">Seafoam Green</option>
                <option value="Surf Green">Surf Green</option>
                <option value="Natural">Natural</option>
                <option value="Cherry Red">Cherry Red</option>[web:2][web:9]
            </select>
        </div>
        <br>
        <div class="option-group">
            <label for="headstock">Headstock:</label>
            <select id="headstock">
                <option value="Fender S-Style">Fender S-Style</option>
                <option value="Gibson LP-Style">Gibson LP-Style</option>
                <option value="Straight">Straight</option>
                <option value="Pointed">Pointed</option>
                <option value="V-Shape">V-Shape</option>[web:3][web:10]
            </select>
        </div>
        <br>
        <div class="option-group">
            <label for="fretboard">Fretboard Wood:</label>
            <select id="fretboard">
                <option value="Rosewood">Rosewood (warm, rich)</option>
                <option value="Maple">Maple (bright, snappy)</option>
                <option value="Ebony">Ebony (dense, clear)</option>[web:4]
            </select>
        </div>
        <br>
        <div class="option-group">
            <label for="bodywood">Body Wood:</label>
            <select id="bodywood">
                <option value="Alder">Alder (vintage, balanced)</option>
                <option value="Mahogany">Mahogany (warm, resonant)</option>
                <option value="Basswood">Basswood (even midrange)</option>
                <option value="Ash">Ash (bright, punchy)</option>[web:5]
            </select>
        </div>
        <br>
        <div class="option-group">
            <label for="pickup">Pickups:</label>
            <select id="pickup">
                <option value="Single Coil">Single Coil (clear, bright)</option>
                <option value="Humbucker">Humbucker (thick, hum-free)</option>
                <option value="P90">P90 (gritty, versatile)</option>
                <option value="Gold Foil">Gold Foil (vintage vibe)</option>[web:6]
            </select>
        </div>
        <br>
        <div class="option-group">
            <label for="hardware">Hardware Color:</label>
            <select id="hardware">
                <option value="Chrome">Chrome (bright, shiny)</option>
                <option value="Nickel">Nickel (warm, aged look)</option>
                <option value="Gold">Gold (luxury)</option>
                <option value="Black">Black (stealth)</option>[web:7]
            </select>
        </div>
        <br>
        <div class="option-group">
            <label for="description">Description (Optional):</label>
            <textarea id="description" placeholder="Add special notes about your custom guitar..."></textarea>
        </div>
        <br>
        <button class="btn btn-primary" onclick="generateSummary();postGuitarBuild();" id="buildBtn"
            style="font-size: 1.3rem; padding: 22px 60px; border-radius: 20px;">Build</button>

        <div id="summary" style="margin-top: 20px; padding: 20px; border-radius: 5px; display: none;"></div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const buildBtn = document.getElementById('buildBtn');
            const statusDiv = document.getElementById('buildStatus');

            // Preview functionality (unchanged)
            const selects = document.querySelectorAll('select, textarea');
            selects.forEach(el => {
                el.addEventListener('change', updatePreview);
                el.addEventListener('input', updatePreview);
            });
        });

        // **BUILD BUTTON = POST TO SERVER**

        function postGuitarBuild() {
            const guitarData = {
                shape: document.getElementById('shape').value,
                color: document.getElementById('color').value,
                headstock: document.getElementById('headstock').value,
                fretboard: document.getElementById('fretboard').value,
                bodywood: document.getElementById('bodywood').value,
                pickup: document.getElementById('pickup').value,
                hardware: document.getElementById('hardware').value,
                description: document.getElementById('description').value
            };

            const buildBtn = document.getElementById('buildBtn');
            buildBtn.disabled = true;

            fetch('/customize', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(guitarData)
            })
                .then(response => response.json())
                .then(result => {
                    // Success message
                    document.getElementById('buildStatus').innerHTML = '✅ Saved!';
                    document.getElementById('buildStatus').style.display = 'block';
                })
                .catch(error => {
                    console.error('Error:', error);
                    document.getElementById('buildStatus').innerHTML = '❌ Error!';
                })
                .finally(() => {
                    buildBtn.textContent = 'Build';
                    buildBtn.disabled = false;
                });
        }


        function generateSummary() {
            const specs = {
                shape: document.getElementById('shape').value,
                color: document.getElementById('color').value,
                headstock: document.getElementById('headstock').value,
                fretboard: document.getElementById('fretboard').value,
                bodywood: document.getElementById('bodywood').value,
                pickup: document.getElementById('pickup').value,
                hardware: document.getElementById('hardware').value,
                description: document.getElementById('description').value
            };

            const summary = document.getElementById('summary');
            summary.innerHTML = `
                <h3>Your Custom Guitar Specs:</h3>
                <ul>
                    <li>${specs.shape} Body - ${specs.color}</li>
                    <li>${specs.headstock} Headstock</li>
                    <li>${specs.fretboard}</li>
                    <li>${specs.bodywood}</li>
                    <li>${specs.pickup}</li>
                    <li>${specs.hardware} Hardware</li>
                    ${specs.description ? `<li>Notes: ${specs.description}</li>` : ''}
                </ul>
                <p><em>Ready to order? Contact us!</em></p>
            `;
            summary.style.display = 'block';
            summary.scrollIntoView({ behavior: 'smooth' });
        }

    </script>
</body>

</html>
